{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "提词器",
  "version": "6.1.0",
  "identifier": "local.codex.teleprompter.tauri",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "index.html",
        "title": "提词器",
        "width": 1280,
        "height": 760,
        "minWidth": 960,
        "minHeight": 560,
        "center": true,
        "decorations": true,
        "dragDropEnabled": false,
        "resizable": true
      },
      {
        "label": "output",
        "url": "index.html?mode=output",
        "title": "提词器输出",
        "width": 1280,
        "height": 720,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "dragDropEnabled": false,
        "skipTaskbar": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  }
}
